{
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md",
      "CLAUDE.md"
    ],
    "includeDirectories": [
      "/Users/zeero/Documents/memos",
      "/Users/zeero/lib/dotfiles/home/.gemini"
    ],
    "loadMemoryFromIncludeDirectories": true
  },
  "mcpServers": {
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "disableAlwaysAllow": false,
    "enablePermanentToolApproval": true,
    "autoAddToPolicyByDefault": true,
    "environmentVariableRedaction": {
      "enabled": true
    }
  },
  "general": {
    "preferredEditor": "neovim",
    "vimMode": false,
    "enableNotifications": true
  },
  "ui": {
    "escapePastedAtSymbols": true,
    "compactToolOutput": false,
    "footer": {
      "hideContextPercentage": false
    },
    "showMemoryUsage": true,
    "showCitations": true,
    "loadingPhrases": "tips"
  },
  "model": {
    "disableLoopDetection": true,
    "name": "auto-gemini-3"
  },
  "experimental": {
    "worktrees": true,
    "modelSteering": true,
    "memoryManager": true,
    "generalistProfile": true,
    "contextManagement": true,
    "topicUpdateNarration": true
  }
}