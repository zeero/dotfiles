{
  "env": {
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "false",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true",
    "CLAUDE_CODE_NO_FLICKER": "false",
    "ENABLE_TOOL_SEARCH": "true",
    "FASTLANE_SKIP_UPDATE_CHECK": "true"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(task:*)",
      "Bash(npm run:*)",
      "Skill(skill-creator)",
      "Skill(kiro:*)",
      "mcp__plugin_context7_context7_*",
      "mcp__*"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(curl -fsSL:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(git -C:*)",
      "Bash(terraform apply -auto-approve:*)",
      "Read(*credential*)",
      "Read(.env*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(sed -i:*)",
      "Bash(gsed -i:*)"
    ],
    "additionalDirectories": [
      "~/Documents/memos"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "alerter --title 'Claude Code' --message '✅ タスクが完了しました' --sound default --timeout 10 &"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "alerter --title 'Claude Code' --message '🕐 入力を待っています' --sound default --timeout 10 &"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline --theme=tokyo-night --style=powerline"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "plugin-dev@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "n8n@skillsforge-marketplace": true,
    "ollama@skillsforge-marketplace": true,
    "ralph-loop@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "pm-market-research@pm-skills": true,
    "superpowers@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "pm-skills": {
      "source": {
        "source": "github",
        "repo": "phuryn/pm-skills"
      },
      "autoUpdate": true
    }
  },
  "language": "Japanese",
  "effortLevel": "medium",
  "promptSuggestionEnabled": false,
  "theme": "dark-ansi",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
